# ============================================================
# LENDING PORTFOLIO RISK INTELLIGENCE PLATFORM
# .gitignore — files that must NEVER be pushed to GitHub
# ============================================================

# ------------------------------------------------------------
# CREDENTIALS & SECRETS
# These files contain private keys and passwords.
# If pushed to GitHub (even a private repo), they can be
# stolen by bots that scan GitHub 24/7 for leaked keys.
# ------------------------------------------------------------
credentials/
*.json
.env
.env.*
!.env.example

# ------------------------------------------------------------
# PYTHON ENVIRONMENT
# The .venv folder contains all installed Python packages.
# It can be 100s of MB and is regenerated with `uv sync`.
# No need to push it — the pyproject.toml + uv.lock are enough.
# ------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# SPARK LOCAL DATA & OUTPUT
# Downloaded parquet files and Spark output are large and
# can be regenerated by running the Spark job again.
# ------------------------------------------------------------
spark/data/
spark/output/

# ------------------------------------------------------------
# dbt
# These are generated files — rebuilt every time dbt runs.
# ------------------------------------------------------------
dbt/lending_club/target/
dbt/lending_club/dbt_packages/
dbt/lending_club/logs/

# ------------------------------------------------------------
# TERRAFORM STATE
# terraform.tfstate contains your real GCP resource IDs.
# Never commit this — use remote state (GCS) in production.
# terraform.tfvars contains your project ID — also keep private.
# ------------------------------------------------------------
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfvars
terraform/.terraform.lock.hcl

# ------------------------------------------------------------
# KESTRA
# Internal Kestra data — not needed in the repo.
# ------------------------------------------------------------
kestra/data/

# ------------------------------------------------------------
# STREAMING / FLINK
# Flink checkpoint data — large, regenerated automatically.
# ------------------------------------------------------------
streaming/checkpoints/
streaming/flink-checkpoints/

# ------------------------------------------------------------
# JUPYTER & IDE
# Editor-specific files — not relevant to other developers.
# ------------------------------------------------------------
.ipynb_checkpoints/
.idea/
.vscode/
*.swp
*.swo

# ------------------------------------------------------------
# OS FILES
# Generated by Mac/Windows/Linux — not part of the project.
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# LOGS
# Log files grow large and contain no useful code.
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# PROJECT DOCUMENTATION (internal only)
# PRD.md and BUILD_JOURNAL.md are internal planning documents.
# They contain detailed build notes not needed by graders.
# The README.md is the public-facing document for GitHub.
# ------------------------------------------------------------
PRD.md
BUILD_JOURNAL.md
