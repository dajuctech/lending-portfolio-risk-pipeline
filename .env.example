# ─────────────────────────────────────────────────────────────
# LENDING PORTFOLIO RISK PIPELINE — Environment Variables
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env to GitHub (already in .gitignore)
#
# WHERE THIS IS USED:
# - kestra/docker-compose.yml  → passes vars to Kestra container
# - dbt/profiles.yml           → BigQuery connection
# - spark/ scripts             → GCP authentication
# - streaming/ scripts         → Kafka + GCP authentication
# ─────────────────────────────────────────────────────────────

# ── GCP Config ───────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcp-project-id-lending-club-raw
GCP_LOCATION=europe-west2
GOOGLE_APPLICATION_CREDENTIALS=../credentials/gcp-service-account.json

# ── Kaggle Config ────────────────────────────────────────────
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_API_TOKEN=your-kaggle-api-token

# ── GCP Service Account JSON (one line) ──────────────────────
# Used by Kestra flows to authenticate with GCP
# Generate with:
# cat credentials/gcp-service-account.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
GCP_SERVICE_ACCOUNT_JSON=
